{
  "$defs": {
    "BrowserConfig": {
      "additionalProperties": false,
      "description": "Browser viewport settings for deterministic captures.",
      "properties": {
        "height": {
          "default": 1000,
          "description": "Viewport height in CSS pixels.",
          "format": "uint32",
          "minimum": 1,
          "type": "integer"
        },
        "width": {
          "default": 1440,
          "description": "Viewport width in CSS pixels.",
          "format": "uint32",
          "minimum": 1,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "CaptureConfig": {
      "additionalProperties": false,
      "description": "Capture timing and output settings.",
      "properties": {
        "default_action_ms": {
          "default": 400,
          "description": "Default animated action duration when duration_ms is omitted.",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "default_hold_ms": {
          "default": 700,
          "description": "Default hold after a step when hold_ms is omitted.",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "output_fps": {
          "default": 24,
          "description": "Frames per second in the generated MP4.",
          "format": "uint32",
          "minimum": 1,
          "type": "integer"
        },
        "show_step_labels": {
          "default": true,
          "description": "Whether to overlay each step name in the recorded video so reviewers know what to notice.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ClickConfig": {
      "additionalProperties": false,
      "description": "Element click action.",
      "properties": {
        "index": {
          "default": null,
          "description": "Which match to click when the selector matches several (0-based).",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "selector": {
          "description": "CSS selector for the element to click.",
          "type": "string"
        }
      },
      "required": [
        "selector"
      ],
      "type": "object"
    },
    "FillConfig": {
      "additionalProperties": false,
      "description": "Input fill action.",
      "properties": {
        "selector": {
          "description": "CSS selector for the input to fill.",
          "type": "string"
        },
        "text": {
          "description": "Text to enter into the matched input.",
          "type": "string"
        }
      },
      "required": [
        "selector",
        "text"
      ],
      "type": "object"
    },
    "ScrollConfig": {
      "additionalProperties": false,
      "description": "Element scroll action.",
      "properties": {
        "pixels": {
          "description": "Vertical pixels to scroll. Negative values scroll upward.",
          "format": "int64",
          "type": "integer"
        },
        "selector": {
          "description": "CSS selector for the element to scroll.",
          "type": "string"
        }
      },
      "required": [
        "selector",
        "pixels"
      ],
      "type": "object"
    },
    "StepConfig": {
      "additionalProperties": false,
      "allOf": [
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "wait_ms",
                  "eval"
                ]
              },
              {
                "required": [
                  "wait_ms",
                  "fill"
                ]
              },
              {
                "required": [
                  "wait_ms",
                  "scroll"
                ]
              },
              {
                "required": [
                  "wait_ms",
                  "click"
                ]
              },
              {
                "required": [
                  "eval",
                  "fill"
                ]
              },
              {
                "required": [
                  "eval",
                  "scroll"
                ]
              },
              {
                "required": [
                  "eval",
                  "click"
                ]
              },
              {
                "required": [
                  "fill",
                  "scroll"
                ]
              },
              {
                "required": [
                  "fill",
                  "click"
                ]
              },
              {
                "required": [
                  "scroll",
                  "click"
                ]
              }
            ]
          }
        }
      ],
      "description": "A named script step. Use at most one action: wait_ms, eval, fill, scroll, or click.",
      "properties": {
        "click": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClickConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Click an element matched by selector."
        },
        "duration_ms": {
          "default": null,
          "description": "Milliseconds used to animate an action such as scrolling.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "eval": {
          "default": null,
          "description": "JavaScript to evaluate in the page.",
          "type": [
            "string",
            "null"
          ]
        },
        "fill": {
          "anyOf": [
            {
              "$ref": "#/$defs/FillConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fill an input matched by selector."
        },
        "frames": {
          "default": null,
          "description": "Explicit number of frames to capture for this step.",
          "format": "uint32",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ]
        },
        "hold_ms": {
          "default": null,
          "description": "Milliseconds to hold the resulting state for viewers.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "name": {
          "minLength": 1,
          "pattern": "\\S",
          "type": "string"
        },
        "screenshot": {
          "default": false,
          "description": "Whether to save a screenshot after this step.",
          "type": "boolean"
        },
        "scroll": {
          "anyOf": [
            {
              "$ref": "#/$defs/ScrollConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Scroll an element matched by selector."
        },
        "wait_for": {
          "anyOf": [
            {
              "$ref": "#/$defs/WaitForConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Wait for a selector before running this step. Does not count as the step action."
        },
        "wait_ms": {
          "default": null,
          "description": "Wait for this many milliseconds before capturing the state.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "WaitForConfig": {
      "additionalProperties": false,
      "description": "Selector precondition for a step.",
      "properties": {
        "selector": {
          "description": "CSS selector to wait for before running the step.",
          "type": "string"
        }
      },
      "required": [
        "selector"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/tdejager/sepia/schemas/sepia-script.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Sepia browser demo script TOML configuration.",
  "properties": {
    "browser": {
      "$ref": "#/$defs/BrowserConfig",
      "default": {
        "height": 1000,
        "width": 1440
      },
      "description": "Browser settings used to make recordings deterministic."
    },
    "capture": {
      "$ref": "#/$defs/CaptureConfig",
      "default": {
        "default_action_ms": 400,
        "default_hold_ms": 700,
        "output_fps": 24,
        "show_step_labels": true
      }
    },
    "description": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "description": "Human-readable demo name.",
      "minLength": 1,
      "pattern": "\\S",
      "type": "string"
    },
    "session": {
      "default": null,
      "description": "Optional stable session name used for output directories.",
      "type": [
        "string",
        "null"
      ]
    },
    "steps": {
      "default": [],
      "description": "Ordered browser actions and captured moments.",
      "items": {
        "$ref": "#/$defs/StepConfig"
      },
      "type": "array"
    },
    "url": {
      "description": "Initial browser URL to open before running the script.",
      "minLength": 1,
      "pattern": "\\S",
      "type": "string"
    }
  },
  "required": [
    "name",
    "url"
  ],
  "title": "DemoConfig",
  "type": "object"
}
